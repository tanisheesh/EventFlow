# Flask
SECRET_KEY=change_me_to_a_random_string
FLASK_ENV=development
FLASK_APP=app.py
DATABASE_URL=sqlite:///eventhub.db
PORT=5000

# Reqly — API observability
# Start the Reqly stack: docker compose up -d  (from the reqly repo root)
# Then set these values. If left empty, EventFlow still works — Reqly is fail-open.
REQLY_COLLECTOR_URL=http://localhost:8000
REQLY_API_KEY=your_ingest_key
